{
    "manifest_version" : 3,
    "name" : "CodeDistill",
    "version" : "1.0",
    "permissions" : ["contextMenus","scripting","clipboardWrite","storage"],
    "description" : "Removes clutter from copied code so developers don't have to clean it manually",
    "background" : {
        "service_worker" : "background.js"
    },
    "host_permissions" : ["<all_urls>"],
    "action" : {
        "default_popup" : "popup.html"
    }
}